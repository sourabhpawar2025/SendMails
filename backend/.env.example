# Copy to .env and fill in your values. Use ONLY the value after = (no quotes needed for simple values).

# Database - scraperdb. MYSQL_HOST must be hostname ONLY (e.g. localhost or 127.0.0.1).
# Do NOT put password in MYSQL_HOST.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=scraperdb

# Redis (for Celery, optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Required for storing SMTP passwords. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Optional
APP_NAME=SMTP Email Sender API
DEBUG=false
